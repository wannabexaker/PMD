# PMD — Raspberry Pi 4 (architecture B) production environment TEMPLATE.
# Copy to .env.production ON THE PI ONLY (it is gitignored) and replace every
# placeholder. Never commit the filled file.

GHCR_OWNER=wannabexaker

# --- Public origin (Vercel SPA) ---
# Used for email links and as the allowed CORS origin. Replace with your domain.
PMD_APP_BASE_URL=https://pmd.example.com
PMD_ALLOWED_ORIGINS=https://pmd.example.com
PMD_ALLOWED_ORIGIN_PATTERNS=

# --- JWT / auth cookies ---
PMD_JWT_SECRET=replace-with-64-char-random-secret
PMD_JWT_EXPIRATIONSECONDS=900
PMD_AUTH_SESSION_COOKIE_SECURE=true
# Lax works with the Vercel same-origin /api rewrite and is friendlier to future
# email links; CSRF is separately enforced by the double-submit token.
PMD_AUTH_SESSION_COOKIE_SAME_SITE=Lax
# Soft launch: no email verification required (turn on once real SMTP is set up).
PMD_AUTH_REQUIRE_VERIFIED_EMAIL=false
PMD_SECURITY_TRUST_PROXY_HEADERS=true

# --- Mongo root + app credentials ---
MONGO_INITDB_ROOT_USERNAME=pmd_root
MONGO_INITDB_ROOT_PASSWORD=replace-root-password
PMD_MONGO_APP_DB=pmd
PMD_MONGO_APP_USER=pmd_app
PMD_MONGO_APP_PASSWORD=replace-app-password
SPRING_DATA_MONGODB_URI=mongodb://pmd_app:replace-app-password@mongo:27017/pmd?authSource=pmd

# --- Mail (disabled for soft launch) ---
# Verification is off, so registration/login need no mail. Invite/notification
# emails no-op until a real SMTP host is configured here.
SPRING_MAIL_HOST=localhost
SPRING_MAIL_PORT=1025
PMD_MAIL_FROM=no-reply@example.com

# --- Google Sign-In + Turnstile (optional; empty = disabled) ---
# Google OAuth 2.0 Web client id (public). Same value as the frontend's
# VITE_GOOGLE_CLIENT_ID. Backend uses it to validate the ID token audience.
PMD_GOOGLE_CLIENT_ID=
# Cloudflare Turnstile secret key (server-side siteverify). Pairs with the
# frontend VITE_TURNSTILE_SITE_KEY.
PMD_TURNSTILE_SECRET=

# --- JVM heap cap for the Pi ---
JAVA_OPTS=-XX:MaxRAMPercentage=70

# --- Cloudflare Tunnel ---
# Zero Trust > Networks > Tunnels > Create a tunnel (Docker) > copy the token.
CLOUDFLARE_TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token
