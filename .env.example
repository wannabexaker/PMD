# Local Docker ports (override as needed)
PMD_BACKEND_PORT=8080
PMD_FRONTEND_PORT=5173
PMD_MONGO_PORT=27017
PMD_SMTP_PORT=1025
PMD_MAILHOG_UI_PORT=8025

# Required for docker-compose.prod.yml
# Use a long random secret (at least 32 chars)
PMD_JWT_SECRET=change-me-to-a-long-random-secret

# Salts the fingerprint stored next to the masked IP. Empty is tolerated locally, but the
# production and Pi stacks require it: without a salt the hash is an unsalted SHA-256 sitting
# beside the cleartext /24, so the "anonymised" IP is recoverable. Generate: openssl rand -hex 32
PMD_SECURITY_CLIENT_METADATA_HASH_SALT=
