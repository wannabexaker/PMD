# --- PMD local-only notes (do not commit) ---
PMD-progress-notes.md
PMD-todo.md

# --- accidental/temp folders (do not commit) ---
hover/
returns/
same/
unchanged/
.runtime/
scripts/.pmd-dev-pids.json

# --- env files (NEVER commit real secrets) ---
.env
.env.*
!.env.example
!.env.production.example
!**/.env.example
!**/.env.production.example

# --- sensitive / internal docs (do not publish) ---
docs/release-checklist.md
docs/FIREWALL_POLICY.md

# --- secrets / keys / certs ---
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
**/secrets/

# --- local tooling outputs ---
graphify-out/
.obsidian/
.claude/
.cursor/

# --- frontend (Vite/React/TS) ---
frontend/**/node_modules/
frontend/**/dist/
frontend/**/build/
frontend/**/.vite/
frontend/**/.env
frontend/**/.env.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- backend (Spring Boot / Maven) ---
backend/**/target/
backend/**/*.log
backend/**/uploads/

# --- logs / db dumps ---
*.log
logs/
*.dump
*.sqlite
*.sqlite3

# --- OS / IDE ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.iml
