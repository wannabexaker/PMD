# PMD production environment template
# Copy to .env.production (or your secret manager) and replace placeholders.

# --- Images / deploy ---
GHCR_OWNER=your-org
PMD_FRONTEND_PORT=80

# --- Domains / CORS ---
# Comma-separated exact origins. Keep strict in production.
PMD_ALLOWED_ORIGINS=https://pmd.example.com,https://pmd-admin.example.com
# Keep empty unless you explicitly need wildcards.
PMD_ALLOWED_ORIGIN_PATTERNS=

# --- JWT / auth cookies ---
PMD_JWT_SECRET=replace-with-64-char-random-secret
PMD_JWT_EXPIRATIONSECONDS=900
PMD_AUTH_SESSION_COOKIE_SECURE=true
PMD_AUTH_SESSION_COOKIE_SAME_SITE=Strict
PMD_AUTH_REQUIRE_VERIFIED_EMAIL=true
PMD_SECURITY_TRUST_PROXY_HEADERS=true

# --- Mongo root + app credentials ---
MONGO_INITDB_ROOT_USERNAME=replace-root-user
MONGO_INITDB_ROOT_PASSWORD=replace-root-password
PMD_MONGO_APP_DB=pmd
PMD_MONGO_APP_USER=pmd_app
PMD_MONGO_APP_PASSWORD=replace-pmd-app-password
SPRING_DATA_MONGODB_URI=mongodb://pmd_app:replace-pmd-app-password@mongo:27017/pmd?authSource=pmd

# --- Mail transport ---
SPRING_MAIL_HOST=smtp.example.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=replace-smtp-username
SPRING_MAIL_PASSWORD=replace-smtp-password
PMD_MAIL_FROM=no-reply@example.com

# --- Security/rate limits ---
PMD_AUTH_RATE_LIMIT_IP_PER_10_MIN=25
PMD_AUTH_RATE_LIMIT_USER_PER_10_MIN=8
PMD_AUTH_RATE_LIMIT_LOCK_MINUTES=20
PMD_RATE_LIMIT_PER_MINUTE=120
PMD_RATE_LIMIT_PER_HOUR=1800

# --- Optional ops ---
PMD_AUDIT_RETENTION_DAYS=365
